# Copy to .env and fill in real values.

# Flask
FLASK_PORT=8000
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-me-to-a-random-string

# Oracle (must match the notebook's connection — same docker container, same users)
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_SYS_USER=sys
ORACLE_SYS_PASS=OraclePwd_2025
ORACLE_AGENT_USER=AGENT
ORACLE_AGENT_PASS=AgentPwd_2025
ORACLE_DEMO_USER=SUPPLYCHAIN
ORACLE_DEMO_PASS=SupplyPwd_2025

# In-DB ONNX embedder model (registered by app/scripts/bootstrap.py — leave as-is
# unless you've registered a different model)
ONNX_EMBED_MODEL=ALL_MINILM_L12_V2
ONNX_EMBED_DIM=384

# -----------------------------------------------------------------------------
# LLM — OCI is the default and only provider for this workshop.
# -----------------------------------------------------------------------------
# The agent's LlmRouter (app/backend/agent/llm.py) routes every chat call to
# the OCI provider configured below. OpenAI variables are intentionally left
# blank so OCI failures surface as errors instead of silently falling back.
# If you want OpenAI as a transparent fallback, fill OPENAI_API_KEY +
# LLM_FALLBACK_MODEL — leaving them empty disables the fallback path.

LLM_PROVIDER=oci
LLM_MODEL=xai.grok-4.3

# OCI GenAI primary
OCI_GENAI_API_KEY=sk-NSQtIMGnQlibGlCar05OtjoEkraPJa73zgusLWbyT1F7ltN2
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-phoenix-1.oci.oraclecloud.com

# OpenAI (disabled — OCI-only). Leave blank.
OPENAI_API_KEY=
LLM_FALLBACK_MODEL=

# Agent loop
AGENT_MAX_ITERATIONS=8
AGENT_BUDGET_SECONDS=60

# OAMP scoping (these are the user_id / agent_id every memory is tagged with)
EDA_USER_ID=enterprise-operator
EDA_AGENT_ID=enterprise-data-agent

# Tavily — gives the agent real-time web/news access via the search_tavily tool.
# Get a key at https://app.tavily.com . Leave blank to disable the tool.
TAVILY_API_KEY=
